# Gemini / Google AI - single key or multiple keys (comma-separated) for rotation
# Required for: server AI horoscope (week/month/year), Rishi agent, and frontend if set as VITE_*
API_KEY=your_gemini_api_key
# Or: GEMINI_API_KEY=your_gemini_api_key  (server uses this for week/month/year horoscope)
# Frontend can use: VITE_GEMINI_API_KEY=... (server will also use it when running locally)
# Multiple keys (rotation): API_KEYS=key1,key2,key3  or  GEMINI_API_KEYS=key1,key2,key3

# Google Maps (geocoding, timezone)
VITE_GOOGLE_API_KEY=your_google_maps_api_key

# Perplexity AI (optional) - for personalized daily forecast & horoscopes
# Single key or multiple keys (comma-separated) - used in rotation
PERPLEXITY_API_KEY=your_perplexity_api_key
# Or: PERPLEXITY_API_KEYS=pplx-key1,pplx-key2,pplx-key3

# Free Astrology API (freeastrologyapi.com) - multiple keys for redundancy (comma-separated)
# API doc: https://documenter.getpostman.com/view/14646401/2sA3XMkQ26
# Keys are rotated when one fails (quota, invalid key). 50 req/day, 1 req/sec per key.
ASTROLOGY_API_KEYS=key1,key2,key3,key4

# Optional: Override astrology API base URL
# ASTROLOGY_API_BASE_URL=https://json.freeastrologyapi.com

# Backend API URL: optional. Leave unset so the app uses local backend (localhost:3001) in dev.
# Cloud Run is a separate API service (for external/API consumers); the frontend does not connect to it.
# Only set VITE_API_BASE_URL if you want the frontend to call a specific backend (e.g. for a custom deploy).
# VITE_API_BASE_URL=https://your-backend.example.com

# Sarvam AI TTS + Translate - Mantra Lab audio and 11 Indian languages (dashboard.sarvam.ai).
VITE_SARVAM_API_KEY=your_sarvam_api_key

# Shunya Labs Translate - 200+ languages for UI (docs.shunyalabs.ai/features/translation).
VITE_SHUNYA_API_KEY=your_shunya_api_key

# Profile consent submit - Google Apps Script Web App URL (see PROFILE_SHEET_SETUP.md)
# When user gives consent and saves, profile data is POSTed to this URL
# REQUIRED for profile data to reach Google Sheet - add to .env.local and GitHub Secrets
VITE_PROFILE_SUBMIT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Google Sign-In (OAuth 2.0 Client ID). For production, set this in your host's env (Vercel/Netlify/etc.).
# VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# User sync (profile + saved reports). For production, set to your LIVE API URL (not localhost).
# See docs/USER_SYNC.md. Must be set in your deployment platform's Environment Variables.
# VITE_SYNC_API_URL=https://your-api.example.com/api/sync

# --- Server (server/ backend) - optional security ---
# CORS_ORIGIN=https://your-frontend.example.com,https://www.example.com
# RATE_LIMIT_MAX=100
# CACHE_CLEAR_SECRET=your-secret-if-you-want-to-protect-POST-/api/cache/clear
# NODE_ENV=production
# If you see "unable to get local issuer certificate" (e.g. Windows/corporate proxy), for local dev only:
# NODE_TLS_REJECT_UNAUTHORIZED=0
# Or: ALLOW_INSECURE_SSL=1
